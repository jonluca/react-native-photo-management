{
  "name": "react-native-photo-management",
  "version": "0.1.3",
  "description": "React Native photo management utilities with batch asset metadata and food detection",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "expo-module build && expo-module build plugin",
    "clean": "expo-module clean && expo-module clean plugin",
    "typecheck": "tsc --noEmit && tsc --noEmit -p plugin/tsconfig.json",
    "lint": "expo-module lint && expo-module lint plugin",
    "test": "expo-module test",
    "prepare": "expo-module prepare",
    "prepublishOnly": "expo-module prepublishOnly",
    "prepack": "npm run clean && npm run build",
    "expo-module": "expo-module",
    "open:ios": "xed example/ios",
    "open:android": "open -a \"Android Studio\" example/android",
    "example:start": "npm --prefix example run start",
    "example:ios": "npm --prefix example run ios",
    "example:android": "npm --prefix example run android",
    "example:prebuild": "npm --prefix example run prebuild"
  },
  "keywords": [
    "react-native",
    "expo",
    "photo-library",
    "media-library",
    "ios",
    "android",
    "expo-module"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jonluca/react-native-photo-management.git"
  },
  "bugs": {
    "url": "https://github.com/jonluca/react-native-photo-management/issues"
  },
  "author": "JonLuca DeCaro <jonluca.decaro@gmail.com> (https://github.com/jonluca)",
  "license": "MIT",
  "homepage": "https://github.com/jonluca/react-native-photo-management#readme",
  "files": [
    "build",
    "android",
    "ios",
    "plugin/build",
    "app.plugin.js",
    "expo-module.config.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "expo-module-scripts": "^55.0.2",
    "expo": "^55.0.6",
    "expo-device": "~55.0.9",
    "expo-media-library": "~55.0.9",
    "react": "19.2.0",
    "react-native": "0.83.2"
  },
  "peerDependencies": {
    "expo": ">=55.0.0",
    "expo-device": ">=55.0.0",
    "expo-media-library": ">=55.0.0",
    "react": "*",
    "react-native": "*"
  }
}
